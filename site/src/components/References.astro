---
const references = [
  "AI-Assisted Development",
  "Project Scaffolding",
  "High-Performance APIs",
  "Docker",
  "Database Architecture",
  "Prisma ORM",
  "dbt Transforms",
  "Authentication",
  "RBAC (permissions)",
  "Validation",
  "Testing",
  "UI Framework",
  "File & Media Uploads",
  "Push Notifications",
  "CI/CD",
  "Pre-commit Hooks",
  "Deployment",
  "Scripts & CLI Tools",
  "Prerequisites & Setup",
];
---

<section
  id="under-the-hood"
  class="border-y border-line bg-paper-raised"
>
  <div class="mx-auto max-w-3xl px-6 py-14 sm:py-20">
    <h2 class="text-2xl font-semibold tracking-tight sm:text-3xl">
      Built on solid ground
    </h2>
    <p class="mt-3 max-w-xl text-pretty leading-relaxed text-ink-soft">
      You don’t need to know any of this. Behind the scenes, Vibe-Spec draws on
      19 battle-tested references built on the same industry-standard tools
      engineers use every day — so what gets built is the real thing, not a
      throwaway prototype. It only uses the pieces your app actually needs.
    </p>

    <ul
      class="mt-8 grid grid-cols-1 gap-x-8 gap-y-2.5 text-sm sm:grid-cols-2"
    >
      {
        references.map((r) => (
          <li class="flex items-baseline gap-2.5 border-b border-line py-2.5">
            <span class="text-accent" aria-hidden="true">
              ✓
            </span>
            <span class="text-ink-soft">{r}</span>
          </li>
        ))
      }
    </ul>

    <p class="mt-6 text-sm text-ink-soft">
      Curious about the details? They’re all on
      <a
        href="https://github.com/Connorrmcd6/vibe-spec"
        class="text-ink underline decoration-accent-soft-line underline-offset-4 hover:decoration-accent"
        target="_blank"
        rel="noopener noreferrer">GitHub</a
      >.
    </p>
  </div>
</section>
