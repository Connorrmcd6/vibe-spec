---
import fs from "node:fs";
import path from "node:path";

// Generated at build time from the actual skill reference files, so the
// copy-paste markdown is always in sync with the plugin. Source of truth:
// ../skills/vibe-spec/reference/*.md (relative to the site/ working dir).
const refDir = path.resolve(
  process.cwd(),
  "..",
  "skills",
  "vibe-spec",
  "reference",
);

const header = `# Vibe-Spec: Stack Reference Guide

A reusable blueprint for building full-stack web apps with Next.js, Prisma, and
PostgreSQL — refined through real production projects using spec-driven
development. Every section is self-contained with skip/need conditions, key
files, copy-pasteable config, and gotchas.

**Only adopt what you need.** Most projects won't need all of it: a static site
doesn't need Prisma or Docker; a simple CRUD app doesn't need S3 or push
notifications. Load only the sections relevant to the task in front of you.
`;

const body = fs
  .readdirSync(refDir)
  .filter((f) => f.endsWith(".md"))
  .sort()
  .map((f) => fs.readFileSync(path.join(refDir, f), "utf8").trim())
  .join("\n\n---\n\n");

const markdown = `${header}\n---\n\n${body}\n`;
const preview = markdown.split("\n").slice(0, 16).join("\n");
const sizeKb = Math.round(markdown.length / 1024);
---

<section id="markdown" class="mx-auto max-w-3xl px-6 py-14 sm:py-20">
  <h2 class="text-2xl font-semibold tracking-tight sm:text-3xl">
    Prefer not to install a plugin?
  </h2>
  <p class="mt-3 max-w-xl text-pretty leading-relaxed text-ink-soft">
    No problem — the whole thing is just markdown. Copy it and paste it into
    Claude, Cursor, or any AI tool, or save it as <code
      class="font-mono text-ink">vibe-spec.md</code
    > in your project so your assistant always has it on hand. It’s the same reference
    the plugin uses, kept in sync automatically.
  </p>

  <div
    id="md-block"
    class="mt-8 overflow-hidden rounded-xl border border-line bg-paper-raised"
  >
    <div
      class="flex items-center justify-between gap-3 border-b border-line px-4 py-2.5"
    >
      <span class="font-mono text-xs text-ink-soft">vibe-spec.md</span>
      <div class="flex items-center gap-2">
        <button
          type="button"
          class="md-copy rounded px-2.5 py-1.5 font-mono text-xs text-ink-soft transition-colors hover:bg-ink/5 hover:text-ink"
        >
          <span class="md-copy-label">Copy</span>
        </button>
        <button
          type="button"
          class="md-download rounded bg-accent px-2.5 py-1.5 font-mono text-xs font-medium text-accent-ink transition-opacity hover:opacity-90"
        >
          Download
        </button>
      </div>
    </div>
    <div class="relative max-h-64 overflow-hidden">
      <pre
        class="overflow-x-auto px-4 py-4 font-mono text-xs leading-relaxed text-ink-soft"><code>{preview}</code></pre>
      <div
        class="pointer-events-none absolute inset-x-0 bottom-0 h-20 bg-gradient-to-t from-paper-raised to-transparent"
      >
      </div>
    </div>
  </div>

  <p class="mt-3 text-xs text-ink-soft">
    18 sections · ~{sizeKb} KB · always current with the plugin.
  </p>
</section>

<script is:inline define:vars={{ markdown }}>
  const block = document.getElementById("md-block");
  if (block) {
    const copyBtn = block.querySelector(".md-copy");
    const label = block.querySelector(".md-copy-label");
    copyBtn?.addEventListener("click", async () => {
      try {
        await navigator.clipboard.writeText(markdown);
        if (label) {
          const prev = label.textContent;
          label.textContent = "Copied!";
          setTimeout(() => (label.textContent = prev), 1500);
        }
      } catch {
        /* clipboard unavailable — no-op */
      }
    });

    block.querySelector(".md-download")?.addEventListener("click", () => {
      const blob = new Blob([markdown], { type: "text/markdown" });
      const url = URL.createObjectURL(blob);
      const a = document.createElement("a");
      a.href = url;
      a.download = "vibe-spec.md";
      a.click();
      URL.revokeObjectURL(url);
    });
  }
</script>
