---
const repo = "https://github.com/Connorrmcd6/vibe-spec";
---

<section id="get-started" class="mx-auto max-w-3xl px-6 py-14 sm:py-20">
  <div class="rounded-3xl bg-accent px-6 py-10 text-center sm:px-10 sm:py-14">
    <h2 class="text-2xl font-semibold tracking-tight text-accent-ink sm:text-3xl">
      Ready to build?
    </h2>
    <p class="mx-auto mt-3 max-w-md text-pretty leading-relaxed text-accent-ink/85">
      Install Vibe-Spec in Claude Code, then describe your first app. The
      workflow takes it from there.
    </p>
    <div class="mt-6 flex flex-wrap items-center justify-center gap-3">
      <code
        class="inline-block rounded-lg bg-ink/15 px-4 py-2.5 font-mono text-sm text-accent-ink"
        >/plugin install vibe-spec</code
      >
      <a
        href={repo}
        class="inline-flex items-center gap-1.5 rounded-lg border border-accent-ink/30 bg-accent-ink/10 px-4 py-2.5 text-sm font-medium text-accent-ink transition-colors hover:bg-accent-ink/20"
        target="_blank"
        rel="noopener noreferrer"
      >
        <span aria-hidden="true">★</span> Star us on GitHub
      </a>
    </div>
  </div>
</section>
