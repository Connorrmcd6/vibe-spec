---
const repo = "https://github.com/Connorrmcd6/vibe-spec";
---

<footer class="border-t border-line">
  <div
    class="mx-auto flex max-w-3xl flex-col gap-6 px-6 py-12 sm:flex-row sm:items-end sm:justify-between"
  >
    <div>
      <p class="font-semibold tracking-tight text-ink">Vibe-Spec</p>
      <p class="mt-1 text-sm text-ink-soft">
        Build real apps by describing them.
      </p>
      <p class="mt-3 text-xs text-ink-soft">
        Inspired by <a
          href="https://impeccable.style"
          class="underline decoration-accent-soft-line underline-offset-4 transition-colors hover:text-ink hover:decoration-accent"
          target="_blank"
          rel="noopener noreferrer">impeccable</a
        >.
      </p>
    </div>
    <nav class="flex items-center gap-6 text-sm text-ink-soft">
      <a
        href={repo}
        class="transition-colors hover:text-ink"
        target="_blank"
        rel="noopener noreferrer">GitHub</a
      >
      <a
        href={`${repo}/blob/main/LICENSE`}
        class="transition-colors hover:text-ink"
        target="_blank"
        rel="noopener noreferrer">MIT License</a
      >
    </nav>
  </div>
</footer>
