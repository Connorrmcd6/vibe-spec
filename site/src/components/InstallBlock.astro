---
const commands = [
  "/plugin marketplace add Connorrmcd6/vibe-spec",
  "/plugin install vibe-spec",
];
const clipboardText = commands.join("\n");
---

<div class="overflow-hidden rounded-lg border border-line bg-paper-raised">
  <div class="flex items-center justify-between border-b border-line px-4 py-2.5">
    <span class="font-mono text-xs text-ink-soft">Paste into Claude Code</span>
    <button
      type="button"
      class="copy-btn -mr-1.5 rounded px-2.5 py-1.5 font-mono text-xs text-ink-soft transition-colors hover:bg-ink/5 hover:text-ink"
      data-clipboard={clipboardText}
      aria-label="Copy install commands"
    >
      <span class="copy-label">Copy</span>
    </button>
  </div>
  <pre class="overflow-x-auto px-4 py-4 font-mono text-xs text-ink sm:text-sm"><code>{commands.map((c) => (
    <span class="block leading-7">{c}</span>
  ))}</code></pre>
</div>
<p class="mt-3 text-sm text-ink-soft">
  That’s it — the workflow is now available. Type <code
    class="font-mono text-ink">/spec-draft</code
  > to begin.
</p>

<script>
  document.querySelectorAll<HTMLButtonElement>(".copy-btn").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const text = btn.dataset.clipboard ?? "";
      const label = btn.querySelector(".copy-label");
      try {
        await navigator.clipboard.writeText(text);
        if (label) {
          const prev = label.textContent;
          label.textContent = "Copied!";
          setTimeout(() => (label.textContent = prev), 1500);
        }
      } catch {
        /* clipboard unavailable — no-op */
      }
    });
  });
</script>
