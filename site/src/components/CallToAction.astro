---
const repo = "https://github.com/Connorrmcd6/vibe-spec";
---

<section class="border-t border-line bg-paper-raised">
  <div class="mx-auto max-w-3xl px-6 py-16 text-center sm:py-24">
    <h2 class="text-balance text-2xl font-semibold tracking-tight sm:text-3xl">
      Ready to build your idea?
    </h2>
    <p
      class="mx-auto mt-3 max-w-xl text-pretty leading-relaxed text-ink-soft"
    >
      Install the workflow in two lines, then describe what you want to build.
      No setup, no boilerplate — just start.
    </p>

    <div
      class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row"
    >
      <a
        href="#install"
        class="inline-flex w-full items-center justify-center rounded-lg bg-accent px-5 py-3 text-sm font-semibold text-accent-ink transition-colors hover:bg-accent/90 sm:w-auto"
      >
        Get started
      </a>
      <a
        href={repo}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex w-full items-center justify-center gap-2 rounded-lg border border-line px-5 py-3 text-sm font-semibold text-ink transition-colors hover:bg-ink/5 sm:w-auto"
      >
        <svg
          viewBox="0 0 16 16"
          width="16"
          height="16"
          fill="currentColor"
          aria-hidden="true"
        >
          <path
            d="M8 .25a8 8 0 0 0-2.53 15.59c.4.07.55-.17.55-.38v-1.34c-2.23.48-2.7-1.07-2.7-1.07-.36-.92-.89-1.17-.89-1.17-.73-.5.05-.49.05-.49.8.06 1.23.83 1.23.83.71 1.22 1.87.87 2.33.66.07-.52.28-.87.5-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.83-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.22 2.2.82a7.6 7.6 0 0 1 4 0c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.52.56.83 1.28.83 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48v2.2c0 .21.15.46.55.38A8 8 0 0 0 8 .25Z"
          ></path>
        </svg>
        Star on GitHub
      </a>
    </div>
  </div>
</section>
